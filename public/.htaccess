Options -MultiViews
DirectoryIndex index.html
RewriteEngine On
RewriteBase /

# Redirect old blog post slug to correct /blog/ hierarchy
RewriteRule ^blog-website-vs-instagram-restaurante/?$ /blog/website-vs-instagram-restaurante [R=301,L,NE]

# Redirect www to non-www (canonical domain)
RewriteCond %{HTTP_HOST} ^www\.zarix\.site [NC]
RewriteRule ^ https://zarix.site%{REQUEST_URI} [R=301,L,NE]

# Redirect .html extension to clean URL (301 for SEO)
RewriteCond %{THE_REQUEST} \s/([^.]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# Redirect trailing slash on non-directory paths
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L,NE]

# Internally serve .html for clean URLs (no redirect, transparent)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^ %{REQUEST_URI}.html [L]
